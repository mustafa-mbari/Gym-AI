# ──────────────────────────────────────────────────────────────────────────
# JYM environment configuration
# Copy this file to `.env.local` and fill in your Supabase project values.
# The app runs in a limited "demo" mode if these are absent, so you can
# explore the UI before wiring up a database.
# ──────────────────────────────────────────────────────────────────────────

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key used by seed scripts and privileged server actions.
# NEVER expose this to the browser. (Project Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of the app (used for OAuth redirects + QR code links).
# Local dev default:
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI Coach (optional) — set an Anthropic API key to enable the in-app coach.
# Without it, the Coach screen shows a setup notice and the rest of the app is
# unaffected. ANTHROPIC_MODEL is optional (defaults to a fast chat model).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
